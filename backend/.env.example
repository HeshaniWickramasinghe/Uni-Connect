# ── Server ────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────────────────
# Replace with your Atlas URI or local connection string
MONGODB_URI=mongodb://localhost:27017/uniconnect

# ── JWT ───────────────────────────────────────────────────────────────────
# Use a long, random string in production
JWT_SECRET=replace_with_a_strong_secret_key
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────────
# Frontend dev server origin
CLIENT_ORIGIN=http://localhost:5173
